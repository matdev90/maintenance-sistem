<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laporan Offline - SIMRS Maintenance</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <style>
    body { background: linear-gradient(135deg, #0c0e1a 0%, #1a1040 100%); min-height: 100vh; color: #fff; }
    .card-offline { background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; }
    .status-badge { position: fixed; top: 10px; right: 10px; z-index: 9999; padding: 8px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
    .status-online { background: #198754; color: white; }
    .status-offline { background: #dc3545; color: white; }
    .pending-count { background: #ffc107; color: #000; }
  </style>
</head>
<body>
  <div class="status-badge" id="statusBadge">
    <i class="bi bi-wifi"></i> <span id="statusText">Online</span>
  </div>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="card card-offline">
          <div class="card-body p-4">
            <div class="text-center mb-4">
              <i class="bi bi-clipboard-data fs-1 text-primary"></i>
              <h4 class="fw-bold mt-2">Laporan Kerusakan Offline</h4>
              <p class="text-white-50 small">Formulir ini bisa digunakan tanpa koneksi internet. Data akan dikirim otomatis saat kembali online.</p>
            </div>

            <div id="pendingInfo" class="alert alert-warning d-none mb-3">
              <i class="bi bi-hourglass-split me-2"></i>
              <span id="pendingCount">0</span> laporan menunggu dikirim.
              <button class="btn btn-sm btn-warning mt-2" onclick="syncNow()" id="btnSync">
                <i class="bi bi-arrow-repeat"></i> Sync Sekarang
              </button>
            </div>

            <form id="offlineForm">
              <div class="mb-3">
                <label class="form-label fw-bold">Unit <span class="text-danger">*</span></label>
                <select name="id_unit" class="form-select" required id="unitSelect">
                  <option value="">Pilih Unit</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Kategori Perangkat <span class="text-danger">*</span></label>
                <select name="id_kategori" class="form-select" required id="kategoriSelect">
                  <option value="">Pilih Kategori</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Nama Perangkat <span class="text-danger">*</span></label>
                <input type="text" name="nama_perangkat" class="form-control" required placeholder="Contoh: Printer Canon iP2770">
              </div>
              <div class="mb-3">
                <label class="form-label fw-bold">Deskripsi Kerusakan</label>
                <textarea name="deskripsi" class="form-control" rows="3" placeholder="Jelaskan kerusakan..."></textarea>
              </div>
              <div class="mb-4">
                <label class="form-label fw-bold">Prioritas</label>
                <select name="prioritas" class="form-select">
                  <option value="ringan">Ringan</option>
                  <option value="sedang" selected>Sedang</option>
                  <option value="berat">Berat</option>
                  <option value="kritis">Kritis</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                <i class="bi bi-send me-2"></i> <span id="submitText">Kirim Laporan</span>
              </button>
            </form>

            <div class="text-center mt-3">
              <a href="/reports" class="text-white-50 small"><i class="bi bi-arrow-left"></i> Kembali ke Aplikasi</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="liveToast" class="toast" role="alert">
      <div class="toast-header">
        <i class="bi bi-info-circle me-2 text-primary"></i>
        <strong class="me-auto">SIMRS</strong>
        <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
      </div>
      <div class="toast-body" id="toastBody"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const DB_NAME = 'simrs_offline';
    const STORE_NAME = 'offline_reports';
    let db = null;

    function openDB() {
      return new Promise((resolve, reject) => {
        const req = indexedDB.open(DB_NAME, 1);
        req.onupgradeneeded = (e) => {
          const database = e.target.result;
          if (!database.objectStoreNames.contains(STORE_NAME)) {
            database.createObjectStore(STORE_NAME, { keyPath: 'id', autoIncrement: true });
          }
        };
        req.onsuccess = () => { db = req.result; resolve(db); };
        req.onerror = () => reject(req.error);
      });
    }

    async function saveOffline(report) {
      const database = await openDB();
      const tx = database.transaction(STORE_NAME, 'readwrite');
      tx.objectStore(STORE_NAME).add(report);
      return new Promise((resolve) => { tx.oncomplete = resolve; });
    }

    async function getOfflineCount() {
      const database = await openDB();
      const tx = database.transaction(STORE_NAME, 'readonly');
      const req = tx.objectStore(STORE_NAME).count();
      return new Promise((resolve) => { req.onsuccess = () => resolve(req.result); });
    }

    async function clearOffline() {
      const database = await openDB();
      const tx = database.transaction(STORE_NAME, 'readwrite');
      tx.objectStore(STORE_NAME).clear();
      return new Promise((resolve) => { tx.oncomplete = resolve; });
    }

    function updateStatus() {
      const badge = document.getElementById('statusBadge');
      const text = document.getElementById('statusText');
      if (navigator.onLine) {
        badge.className = 'status-badge status-online';
        text.textContent = 'Online';
      } else {
        badge.className = 'status-badge status-offline';
        text.textContent = 'Offline';
      }
    }

    async function updatePendingInfo() {
      const count = await getOfflineCount();
      const info = document.getElementById('pendingInfo');
      const countEl = document.getElementById('pendingCount');
      if (count > 0) {
        info.classList.remove('d-none');
        countEl.textContent = count;
      } else {
        info.classList.add('d-none');
      }
    }

    async function syncNow() {
      if (!navigator.onLine) {
        showToast('Tidak ada koneksi internet. Sync ditunda.');
        return;
      }
      const btn = document.getElementById('btnSync');
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Syncing...';

      try {
        const database = await openDB();
        const tx = database.transaction(STORE_NAME, 'readonly');
        const reports = await new Promise((resolve) => {
          const req = tx.objectStore(STORE_NAME).getAll();
          req.onsuccess = () => resolve(req.result);
        });

        let synced = 0;
        for (const report of reports) {
          try {
            const formData = new FormData();
            formData.append('id_unit', report.id_unit);
            formData.append('id_kategori', report.id_kategori);
            formData.append('nama_perangkat', report.nama_perangkat);
            formData.append('deskripsi', report.deskripsi || '');
            formData.append('prioritas', report.prioritas || 'sedang');

            const resp = await fetch('/reports/store', { method: 'POST', body: formData, credentials: 'same-origin' });
            if (resp.ok || resp.redirected) synced++;
          } catch (e) {}
        }

        if (synced > 0) {
          await clearOffline();
          showToast(synced + ' laporan berhasil dikirim!');
        } else {
          showToast('Gagal mengirim laporan. Coba lagi nanti.');
        }
      } catch (e) {
        showToast('Error syncing: ' + e.message);
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-arrow-repeat"></i> Sync Sekarang';
      updatePendingInfo();
    }

    function showToast(msg) {
      document.getElementById('toastBody').textContent = msg;
      new bootstrap.Toast(document.getElementById('liveToast')).show();
    }

    document.getElementById('offlineForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const data = {
        id_unit: form.id_unit.value,
        id_kategori: form.id_kategori.value,
        nama_perangkat: form.nama_perangkat.value,
        deskripsi: form.deskripsi.value,
        prioritas: form.prioritas.value,
        created_at: new Date().toISOString()
      };

      if (!data.id_unit || !data.nama_perangkat) {
        showToast('Unit dan Nama Perangkat wajib diisi!');
        return;
      }

      if (navigator.onLine) {
        try {
          const formData = new FormData();
          formData.append('id_unit', data.id_unit);
          formData.append('id_kategori', data.id_kategori);
          formData.append('nama_perangkat', data.nama_perangkat);
          formData.append('deskripsi', data.deskripsi);
          formData.append('prioritas', data.prioritas);

          const resp = await fetch('/reports/store', { method: 'POST', body: formData, credentials: 'same-origin' });
          if (resp.ok || resp.redirected) {
            showToast('Laporan berhasil dikirim!');
            form.reset();
            return;
          }
        } catch (e) {}
      }

      await saveOffline(data);
      showToast('Laporan disimpan offline. Akan dikirim saat online.');
      form.reset();
      updatePendingInfo();
    });

    window.addEventListener('online', () => { updateStatus(); syncNow(); });
    window.addEventListener('offline', updateStatus);

    async function loadData() {
      try {
        const resp = await fetch('/reports/units-categories');
        if (resp.ok) {
          const data = await resp.json();
          const unitSel = document.getElementById('unitSelect');
          const kategoriSel = document.getElementById('kategoriSelect');
          (data.units || []).forEach(u => {
            unitSel.innerHTML += '<option value="' + u.id + '">' + u.nama_unit + '</option>';
          });
          (data.categories || []).forEach(c => {
            kategoriSel.innerHTML += '<option value="' + c.id + '">' + c.nama_kategori + '</option>';
          });
        }
      } catch (e) {}
    }

    updateStatus();
    openDB().then(updatePendingInfo);
    loadData();
  </script>
</body>
</html>
