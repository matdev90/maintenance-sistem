<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <a href="/reports/create" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Buat Laporan
    </a>
  </div>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <form id="filterForm" class="auto-filter row g-2 align-items-end">
      <div class="col-md-2">
        <label class="form-label small">Pencarian</label>
        <input type="text" name="q" class="form-control form-control-sm filter-input" placeholder="Nama perangkat..." value="<%= filters.q || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small">Unit</label>
        <select name="unit" class="form-select form-select-sm filter-input">
          <option value="">Semua Unit</option>
          <% units.forEach(function(u) { %>
          <option value="<%= u.id %>" <%= filters.unit == u.id ? 'selected' : '' %>><%= u.nama_unit %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small">Prioritas</label>
        <select name="prioritas" class="form-select form-select-sm filter-input">
          <option value="">Semua</option>
          <option value="ringan" <%= filters.prioritas === 'ringan' ? 'selected' : '' %>>Ringan</option>
          <option value="sedang" <%= filters.prioritas === 'sedang' ? 'selected' : '' %>>Sedang</option>
          <option value="berat" <%= filters.prioritas === 'berat' ? 'selected' : '' %>>Berat</option>
          <option value="kritis" <%= filters.prioritas === 'kritis' ? 'selected' : '' %>>Kritis</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small">Status</label>
        <select name="status" class="form-select form-select-sm filter-input">
          <option value="">Semua</option>
          <option value="dilaporkan" <%= filters.status === 'dilaporkan' ? 'selected' : '' %>>Dilaporkan</option>
          <option value="divalidasi" <%= filters.status === 'divalidasi' ? 'selected' : '' %>>Divalidasi</option>
          <option value="investigasi" <%= filters.status === 'investigasi' ? 'selected' : '' %>>Investigasi</option>
          <option value="dalam_perbaikan" <%= filters.status === 'dalam_perbaikan' ? 'selected' : '' %>>Dalam Perbaikan</option>
          <option value="selesai" <%= filters.status === 'selesai' ? 'selected' : '' %>>Selesai</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small">Dari</label>
        <input type="date" name="dari" class="form-control form-control-sm filter-input" value="<%= filters.dari || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label small">Sampai</label>
        <input type="date" name="sampai" class="form-control form-control-sm filter-input" value="<%= filters.sampai || '' %>">
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th style="width:50px">No.</th>
            <th>Unit</th>
            <th>Kategori</th>
            <th>Perangkat</th>
            <th>Prioritas</th>
            <th>Status</th>
            <th>Pelapor</th>
            <th>Tanggal</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (reports.length === 0) { %>
          <tr><td colspan="9" class="text-center text-muted py-4">Tidak ada data</td></tr>
          <% } %>
          <% reports.forEach(function(r, i) { %>
          <tr>
            <td><%= ((pagination.currentPage || 1) - 1) * (pagination.limit || 15) + i + 1 %></td>
            <td><%= r.unit ? r.unit.nama_unit : '-' %></td>
            <td><%= r.kategori ? r.kategori.nama_kategori : '-' %></td>
            <td><%= r.nama_perangkat %></td>
            <td>
              <% var pc = {ringan:'bg-success', sedang:'bg-warning', berat:'bg-danger', kritis:'bg-dark'} %>
              <span class="badge <%= pc[r.prioritas] || 'bg-secondary' %>"><%= r.prioritas %></span>
            </td>
            <td>
              <% var sc = {dilaporkan:'bg-secondary', divalidasi:'bg-info', investigasi:'bg-primary', dalam_perbaikan:'bg-warning', selesai:'bg-success', tidak_valid:'bg-danger', tidak_dapat_diperbaiki:'bg-danger'} %>
              <span class="badge <%= sc[r.status] || 'bg-secondary' %>"><%= r.status.replace(/_/g,' ') %></span>
            </td>
            <td><%= r.pelapor ? r.pelapor.nama_lengkap : '-' %></td>
            <td><%= r.created_at ? new Date(r.created_at).toLocaleDateString('id-ID') : '-' %></td>
            <td>
              <a href="/reports/<%= r.id %>" class="btn btn-sm btn-info" title="Detail">
                <i class="bi bi-eye"></i>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <%- include('../partials/pagination', { pagination, filters }) %>
  </div>
</div>


