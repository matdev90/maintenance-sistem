<style>
  .log-detail-json pre { font-size: .8rem; background: #f8f9ff; padding: 1rem; border-radius: 8px; max-height: 400px; overflow: auto; }
</style>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-journal-text me-1"></i> Detail Log #<%= log.id %></span>
    <a href="/admin/logs" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Kembali</a>
  </div>
  <div class="card-body">
    <table class="table table-bordered table-sm">
      <tr><th width="140">ID Log</th><td><%= log.id %></td></tr>
      <tr><th>Waktu</th><td><%= fmtDate(log.created_at) %></td></tr>
      <tr><th>User</th><td><%= log.username || '-' %></td></tr>
      <tr><th>ID User</th><td><%= log.id_user || '-' %></td></tr>
      <tr><th>Aksi</th><td><span class="badge bg-primary"><%= log.action %></span></td></tr>
      <tr><th>Tipe Entitas</th><td><%= log.entity_type || '-' %></td></tr>
      <tr><th>ID Entitas</th><td><%= log.entity_id || '-' %></td></tr>
      <tr><th>IP Address</th><td><%= log.ip_address || '-' %></td></tr>
    </table>

    <% if (log.detail) { %>
    <h6 class="mt-3">Detail (JSON)</h6>
    <div class="log-detail-json">
      <pre><%= JSON.stringify(JSON.parse(log.detail), null, 2) %></pre>
    </div>
    <% } %>
  </div>
</div>
