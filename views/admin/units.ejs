<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="mb-0"><i class="bi bi-building me-2"></i>Daftar Unit</h5>
  <a href="/admin/units/create" class="btn btn-primary btn-3d">
    <i class="bi bi-plus-circle"></i> Tambah Unit
  </a>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <form id="filterForm" class="auto-filter row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label small">Pencarian</label>
        <input type="text" name="q" class="form-control form-control-sm filter-input" placeholder="Nama unit..." value="<%= (filters && filters.q) || '' %>">
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-striped mb-0">
      <thead>
        <tr><th style="width:60px">No.</th><th>Nama Unit</th><th style="width:160px">Aksi</th></tr>
      </thead>
      <tbody>
        <% units.forEach(function(u, i) { %>
        <tr>
          <td><%= ((pagination.currentPage || 1) - 1) * (pagination.limit || 15) + i + 1 %></td>
          <td><%= u.nama_unit %></td>
          <td>
            <a href="/admin/units/<%= u.id %>/edit" class="btn btn-sm btn-warning">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form action="/admin/units/<%= u.id %>/delete" method="POST" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="button" class="btn btn-sm btn-danger" data-3d-delete data-confirm-msg="Hapus unit <strong><%= u.nama_unit %></strong>?<br><small class='text-muted'>Data yang dihapus tidak dapat dikembalikan.</small>">
                <i class="bi bi-trash"></i> Hapus
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (units.length === 0) { %>
        <tr><td colspan="3" class="text-center text-muted py-4">Tidak ada data</td></tr>
        <% } %>
      </tbody>
    </table>
    <%- include('../partials/pagination', { pagination, filters: filters || {} }) %>
  </div>
</div>


