<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th width="40">No</th>
          <th>Nama</th>
          <th>Unit</th>
          <th>Spesialisasi</th>
          <th>Tugas Aktif</th>
          <th>Max Tugas</th>
          <th>Status</th>
          <th width="80">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% technicians.forEach(function(t, i) { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><strong><%= t.nama_lengkap %></strong></td>
          <td><%= t.unit ? t.unit.nama_unit : '-' %></td>
          <td><span class="text-muted"><%= t.techProfile ? (t.techProfile.spesialisasi || '-') : '-' %></span></td>
          <td>
            <span class="badge bg-info"><%= t.totalActive %></span>
            <small class="text-muted">(L: <%= t.activeReports %> / T: <%= t.activeTickets %>)</small>
          </td>
          <td><%= t.techProfile ? t.techProfile.max_tugas_aktif : 5 %></td>
          <td>
            <% if (t.techProfile && t.techProfile.is_available) { %>
            <span class="badge bg-success">Tersedia</span>
            <% } else { %>
            <span class="badge bg-secondary">Tidak Tersedia</span>
            <% } %>
          </td>
          <td>
            <a href="/admin/technicians/<%= t.id %>/edit" class="btn btn-sm btn-outline-primary btn-3d"><i class="bi bi-pencil"></i></a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
