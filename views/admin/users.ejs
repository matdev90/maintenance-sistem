<div class="d-flex justify-content-between mb-3">
  <a href="/admin/users/create" class="btn btn-primary btn-3d"><i class="bi bi-plus-circle"></i> Tambah Pengguna</a>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <form id="filterForm" class="auto-filter row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label small">Pencarian</label>
        <input type="text" name="q" class="form-control form-control-sm filter-input" placeholder="Username atau nama..." value="<%= (filters && filters.q) || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small">Role</label>
        <select name="role" class="form-select form-select-sm filter-input">
          <option value="">Semua Role</option>
          <option value="admin" <%= (filters && filters.role === 'admin') ? 'selected' : '' %>>Admin</option>
          <option value="teknisi" <%= (filters && filters.role === 'teknisi') ? 'selected' : '' %>>Teknisi</option>
          <option value="pelapor" <%= (filters && filters.role === 'pelapor') ? 'selected' : '' %>>Pelapor</option>
        </select>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-striped mb-0">
      <thead>
        <tr>
          <th style="width:60px">No.</th>
          <th>Username</th>
          <th>Nama Lengkap</th>
          <th>Role</th>
          <th>Unit</th>
          <th style="width:160px">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u, i) { %>
        <tr>
          <td><%= ((pagination.currentPage || 1) - 1) * (pagination.limit || 15) + i + 1 %></td>
          <td><%= u.username %></td>
          <td><%= u.nama_lengkap %></td>
          <td><span class="badge <%= {admin:'bg-danger', teknisi:'bg-primary', pelapor:'bg-success'}[u.role] %>"><%= u.role %></span></td>
          <td><%= u.unit ? u.unit.nama_unit : '-' %></td>
          <td>
            <a href="/admin/users/<%= u.id %>/edit" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Edit</a>
            <% if (u.role !== 'admin') { %>
            <form action="/admin/users/<%= u.id %>/delete" method="POST" style="display:inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="button" class="btn btn-sm btn-danger" data-3d-delete data-confirm-msg="Hapus pengguna <strong><%= u.nama_lengkap %></strong>?<br><small class='text-muted'>Data yang dihapus tidak dapat dikembalikan.</small>">
                <i class="bi bi-trash"></i> Hapus
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
        <% if (users.length === 0) { %>
        <tr><td colspan="6" class="text-center text-muted py-4">Tidak ada data</td></tr>
        <% } %>
      </tbody>
    </table>
    <%- include('../partials/pagination', { pagination, filters: filters || {} }) %>
  </div>
</div>


