<div class="card" style="max-width:500px">
  <div class="card-body">
    <form method="POST" action="<%= unit ? '/admin/units/' + unit.id + '/update' : '/admin/units/store' %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="mb-3">
        <label class="form-label">Nama Unit <span class="text-danger">*</span></label>
        <input type="text" name="nama_unit" class="form-control form-control-lg" value="<%= unit ? unit.nama_unit : '' %>" required autofocus>
      </div>
      <button type="submit" class="btn btn-primary btn-3d"><i class="bi bi-save me-1"></i> Simpan</button>
      <a href="/admin/units" class="btn btn-secondary btn-3d">Batal</a>
    </form>
  </div>
</div>